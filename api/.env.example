# Pulse backend configuration. Copy to .env and fill in as needed.
# Everything has a working default — the app runs with no .env at all.

# SQLite by default (zero-config). Point at Postgres later: postgresql+psycopg://...
DATABASE_URL=sqlite:///./pulse.db

# Single-user gate. Leave blank to disable the token check (dev default).
APP_TOKEN=

# --- Free structured sources (no key) ---------------------------------------
# Curated public sources ship in app/feeds.py (UC Berkeley ICS, Toronto Open Data,
# Eventbrite GTA listings via JSON-LD). Add more .ics feeds:
#   ICS_FEEDS=https://example.edu/live/ical/events|Boston|42.3601|-71.0589
ICS_FEEDS=
# Generic registry entries (CKAN/Localist/JSON-LD/RSS):
#   SOURCE_DEFS=jsonld|Eventbrite (NYC)|New York|40.71|-74.0|https://www.eventbrite.com/d/ny--new-york/all-events/
SOURCE_DEFS=

# Real geocoding of civic addresses → "centroid" (offline default) | "nominatim"
# (real, cached, strict 1 req/s, budgeted). Nominatim is free but rate-limited.
GEOCODER=centroid
# Fill missing event images from page og:image (network; off by default).
ENABLE_IMAGE_ENRICH=false

# --- Keyed sources (multi-key CSV → failover) -------------------------------
# Ticketmaster (free key, ~1 min at developer-acct.ticketmaster.com). With a key,
# real events flow and the demo seed steps aside.
TICKETMASTER_API_KEY=
# SeatGeek client_id (free, seatgeek.com/build).
SEATGEEK_CLIENT_ID=

# --- Paid amplifiers (disabled stubs unless set) ----------------------------
SERPAPI_KEY=          # google_events meta-aggregator + powers DiscoverySource
PREDICTHQ_TOKEN=      # aggregated community/festival events, ranked
MEETUP_TOKEN=         # hobby/community meetups (kite-flying etc.), GraphQL
ENABLE_LLM_EXTRACTION=false

# CORS origin for the Vite frontend.
FRONTEND_ORIGIN=http://localhost:5173
