{
  "version": 2,
  "builds": [
    {
      "src": "full.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "app/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "full.py"
    }
  ],
  "crons": [
    {
      "path": "/cron/refresh-all",
      "schedule": "0 * * * *"
    }
  ]
}
