{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/events/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/pulse/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Bodoni Moda|EB Garamond|Oswald|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Bodoni Moda, EB Garamond, Oswald, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|inverse|ok|warn|error)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'inverse' | 'ok' | 'warn' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|icon|badge|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: key, label, icon, badge."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|iconLeft|iconRight|disabled|loading|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, iconLeft, iconRight, disabled, loading."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:interactive|inverse|padding|elevation|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: interactive, inverse, padding, elevation."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DatePicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<DatePicker> doesn't accept that prop. Declared props: value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DigestItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|event|onOpen|key|ref|className|style|children)$/]",
        "message": "<DigestItem> doesn't accept that prop. Declared props: index, event, onOpen."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|body|action|glyph|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: title, body, action, glyph."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute[name.name='glyph'] > Literal[value!=/^(?:map|search|saved|quiet|error)$/]",
        "message": "<EmptyState> glyph must be one of 'map' | 'search' | 'saved' | 'quiet' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PulseEvent'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|category|date|venue|distance|price|free|relevance|sources|freshness|gem|score|imageStyle|key|ref|className|style|children)$/]",
        "message": "<PulseEvent> doesn't accept that prop. Declared props: title, category, date, venue, distance, price, free, relevance, sources, freshness, gem, score, imageStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:filters|active|onToggle|sticky|key|ref|className|style|children)$/]",
        "message": "<FilterBar> doesn't accept that prop. Declared props: filters, active, onToggle, sticky."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|icon|count|key|ref|className|style|children)$/]",
        "message": "<FilterChip> doesn't accept that prop. Declared props: active, icon, count."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|round|active|disabled|label|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size, round, active, disabled, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|outline|solid)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'outline' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|iconLeft|size|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, iconLeft, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LocationSwitcher'] > JSXAttribute > JSXIdentifier[name!=/^(?:city|loading|statusText|size|onClick|key|ref|className|style|children)$/]",
        "message": "<LocationSwitcher> doesn't accept that prop. Declared props: city, loading, statusText, size, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='LocationSwitcher'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<LocationSwitcher> size must be one of 'md' | 'lg'."
